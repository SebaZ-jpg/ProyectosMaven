<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      alignment="CENTER"
      stylesheets="/styles/styles.css"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dam.code.controller.InicioController">

    <Label text="Iniciar sesión" style="-fx-font-size: 20;"/>

    <Label text="DNI"/>
    <TextField fx:id="tfDni" promptText="12345678A"/>

    <Label text="Contraseña"/>
    <PasswordField fx:id="pfPassword" promptText="Contraseña"/>

    <Button text="Entrar" onAction="#onLogin" maxWidth="Infinity"/>
    <Button text="¿No tienes cuenta? Regístrate" onAction="#onIrARegistro"
            maxWidth="Infinity"/>

</VBox>