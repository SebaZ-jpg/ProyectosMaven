<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      alignment="CENTER"
      stylesheets="/styles/styles.css"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dam.code.controller.RegistroController">

    <Label text="Crear cuenta" style="titlle"/>

    <Label text="DNI"/>
    <TextField fx:id="tfDni" promptText="12345678A"/>

    <Label text="Nombre"/>
    <TextField fx:id="tfNombre" promptText="Nombre"/>

    <Label text="Apellido"/>
    <TextField fx:id="tfApellido" promptText="Apellido"/>

    <Label text="Email"/>
    <TextField fx:id="tfEmail" promptText="correo@ejemplo.com"/>

    <Label text="Contraseña"/>
    <PasswordField fx:id="tfPassword" promptText="Contraseña"/>

    <Button text="Registrarse" onAction="#onRegistrar" maxWidth="Infinity"/>
    <Button text="¿Ya tienes cuenta? Inicia sesión" onAction="#onIrALogin"
            maxWidth="Infinity"/>

</VBox>