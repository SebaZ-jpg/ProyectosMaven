<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      alignment="CENTER"
      stylesheets="/styles/styles.css"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="dam.code.controller.PeliculaController">

    <Label text="Gestión de Peliculas" styleClass="title"/>

    <TableView fx:id="tablaPeliculas" VBox.vgrow="ALWAYS">

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>

        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
            <TableColumn fx:id="colTitulo" text="Título" prefWidth="180"/>
            <TableColumn fx:id="colDirector" text="Director" prefWidth="150"/>
            <TableColumn fx:id="colDuracion" text="Duración (min)" prefWidth="110"/>
            <TableColumn fx:id="colFecha" text="Fecha Publicación" prefWidth="130"/>
            <TableColumn fx:id="colVisualizaciones" text="Visualizaciones" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtId" promptText="ID (3 letras + 2 números)" styleClass="input" prefWidth="160"/>
        <TextField fx:id="txtTitulo" promptText="Título" styleClass="input" prefWidth="160"/>
        <TextField fx:id="txtDirector" promptText="Director" styleClass="input" prefWidth="160"/>
        <TextField fx:id="txtDuracion" promptText="Duración" styleClass="input" prefWidth="100"/>
        <DatePicker fx:id="dpFecha" promptText="Fecha"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Agregar" onAction="#onAgregar" styleClass="boton-primary"/>
        <Button text="Editar Título" onAction="#onEditarTitulo" styleClass="boton-primary"/>
        <Button text="Editar Fecha" onAction="#onEditarFecha" styleClass="boton-primary"/>
        <Button text="Eliminar" onAction="#onEliminar" styleClass="button-danger"/>
    </HBox>

    <Button text="Cerrar Sesión" onAction="#onCerrarSesion" styleClass="boton-link"/>

</VBox>